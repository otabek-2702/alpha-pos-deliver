# Alpha POS Courier — runtime config (read via expo-constants `extra` / EXPO_PUBLIC_*).
# Leave API/WS blank to run fully on typed mock fixtures + the fake WS emitter.

# REST base, e.g. https://api.alphapos.uz
EXPO_PUBLIC_API_BASE_URL=

# Django Channels WS base, e.g. wss://api.alphapos.uz  (courier socket = <ws>/ws/courier/)
EXPO_PUBLIC_WS_BASE_URL=

# "true" forces mock data + fake WS even if the URLs above are set.
EXPO_PUBLIC_USE_MOCK=true
