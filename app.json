{
  "expo": {
    "name": "Alfa POS",
    "slug": "alfa-pos-courier",
    "scheme": "alfacourier",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "uz.alfapos.courier",
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "yandexnavi",
          "yandexmaps",
          "comgooglemaps",
          "dgis"
        ]
      }
    },
    "android": {
      "package": "uz.alfapos.courier",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#3A5BDB"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": []
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#3A5BDB",
          "image": "./assets/splash.png",
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "",
      "wsBaseUrl": "",
      "useMock": true,
      "router": {},
      "eas": {
        "projectId": "944805db-0860-4ef7-be20-d407eccf245a"
      }
    },
    "owner": "adrian_2702"
  }
}
